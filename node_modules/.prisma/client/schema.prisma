generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Trail {
  id                 Int     @id @default(autoincrement())
  name               String
  trailType          String
  description        String?
  lengthKm           Float?
  casualWalk         Boolean @default(false)
  forestedTrail      Boolean @default(false)
  floraFaunaSpotting Boolean @default(false)
  wildlifeSpotting   Boolean @default(false)
  north              Boolean @default(false)
  south              Boolean @default(false)
  east               Boolean @default(false)
  west               Boolean @default(false)
  central            Boolean @default(false)

  // Discovery & Difficulty
  difficulty     String?
  estimatedHours Float?
  elevationGainM Int?
  terrainType    String?

  // Accessibility & Logistics
  nearestMRT       String?
  parkingAvail     String?
  dogFriendly      Boolean @default(false)
  wheelchairAccess Boolean @default(false)
  toilets          Boolean @default(false)
  shelters         Boolean @default(false)

  // Status
  isActive      Boolean   @default(true)
  closureReason String?
  closureUntil  DateTime?

  // Coordinates
  lat Float?
  lng Float?

  @@map("trails")
}
