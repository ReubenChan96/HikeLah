<!DOCTYPE html>
<html lang="en">
    <head>
        <link rel="icon" href="/assets/img/signpost.png">
        <script async src="https://www.googletagmanager.com/gtag/js?id=G-FPZ4SZV14K"></script>
        <script>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
        
          gtag('config', 'G-FPZ4SZV14K');
        </script>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Explore - Hikelah!</title>
    
        
        <!--Link to Bootstrap and Popper Framework-->
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
        <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js" integrity="sha384-I7E8VVD/ismYTF4hNIPjVp/Zjvgyol6VFvRkX/vR+Vc4jQkC+hVqc2pM8ODewa9r" crossorigin="anonymous"></script>

        <!--Link to custom styles-->
        <link rel="stylesheet" href="/css/hikelah_style.css">

        <!--Link to Google Font API for custom fonts-->
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@400..700&family=Inter:wght@100..900&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Open+Sans:ital,wght@0,300..800;1,300..800&display=swap" rel="stylesheet">

        <!--Link to script.js-->
        <script src="/js/script.js"></script>
        
        <script>
            document.addEventListener("DOMContentLoaded", function() {
                var card = document.getElementById("measure-card");
            });
        </script>
    </head>
    
    <body>
      <%- include('partials/navbar.ejs'); %>
      <!--Alert Banner-->
      <div class="container alert alert-secondary alert-dismissible fade show" role="alert">
        <strong>Coming Soon:</strong> Detailed Trail Maps, Flora/Fauna and Animal Sightings, notable landmarks around the trail, and user reviews!
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>


    <div class="container d-flex justify-content-center">
      <div class="col-12 mb-4">
        <img class="hero-image image-fluid" src="/assets/img/explore-banner.png" alt="image of a hiking trail in Singapore " />        
      </div>
    </div>
    <br />
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-12 text-center">
          <h1 class="page-head center-page-head">Let's Hike!</h1>
      </div>
    </div>
    <br />

    <!--Check box Filters-->
    <div class="d-flex justify-content-center mb-4">
    <div class="row gx-4">
      <div class="col-auto">
          <div class="dropdown mb-3 custom-dropdown">
              <button class="btn btn-secondary dropdown-toggle" type="button" id="regionDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                  Region
              </button>
              <ul class="dropdown-menu" aria-labelledby="regionDropdown">
                  <li><div class="form-check"><input class="form-check-input" type="checkbox" value="region-north" id="filter-north"><label class="form-check-label" for="filter-north">North</label></div></li>
                  <li><div class="form-check"><input class="form-check-input" type="checkbox" value="region-south" id="filter-south"><label class="form-check-label" for="filter-south">South</label></div></li>
                  <li><div class="form-check"><input class="form-check-input" type="checkbox" value="region-east" id="filter-east"><label class="form-check-label" for="filter-east">East</label></div></li>
                  <li><div class="form-check"><input class="form-check-input" type="checkbox" value="region-west" id="filter-west"><label class="form-check-label" for="filter-west">West</label></div></li>
                  <li><div class="form-check"><input class="form-check-input" type="checkbox" value="region-central" id="filter-central"><label class="form-check-label" for="filter-central">Central</label></div></li>
              </ul>
          </div>
      </div>

      <div class="col-auto">
          <div class="dropdown mb-3 custom-dropdown">
              <button class="btn btn-secondary dropdown-toggle" type="button" id="typeDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                  Type
              </button>
              <ul class="dropdown-menu" aria-labelledby="typeDropdown">
                  <li><div class="form-check"><input class="form-check-input" type="checkbox" value="type-challenge" id="filter-challenge"><label class="form-check-label" for="filter-challenge">Challenge Trail</label></div></li>
                  <li><div class="form-check"><input class="form-check-input" type="checkbox" value="type-park" id="filter-park"><label class="form-check-label" for="filter-park">Nature Park</label></div></li>
                  <li><div class="form-check"><input class="form-check-input" type="checkbox" value="type-connector" id="filter-connector"><label class="form-check-label" for="filter-connector">Park Connector</label></div></li>
              </ul>
          </div>
      </div>

      <div class="col-auto">
          <div class="dropdown mb-3 custom-dropdown">
              <button class="btn btn-secondary dropdown-toggle" type="button" id="terrainDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                  Terrain
              </button>
              <ul class="dropdown-menu" aria-labelledby="terrainDropdown">
                  <li><div class="form-check"><input class="form-check-input" type="checkbox" value="trail-walk" id="filter-trail-walk"><label class="form-check-label" for="filter-trail-walk">Paved Trails</label></div></li>
                  <li><div class="form-check"><input class="form-check-input" type="checkbox" value="trail-forest" id="filter-trail-forest"><label class="form-check-label" for="filter-trail-forest">Gravel/Off-road Trails</label></div></li>
              </ul>
          </div>
      </div>
  </div>

    </div>

    <!--Filter pill generator-->

    <div class="filters mt-3">
      <div class="d-flex flex-wrap align-items-center">

        <h5>Selected filters:</h5>
        <div class="ms-3">
          <div id="filter-pills-container" class="d-flex flex-wrap"></div>

      </div>
  </div>

    </div>

    <hr class="break-line"/>


    <!--Explore and Map buttons-->

    <!--Trail cards served dynamically from Supabase PostgreSQL via Prisma.
         Display-only fields (images, guide URLs, extra pills) are merged from public/data/trail-metadata.json.
         Add new trails via prisma db seed or directly in the DB.-->
    <div class="container search">
      <div class="cards-container">
        <% trails.forEach(function(trail) { %>
          <%- include('partials/search-card', trail) %>
        <% }) %>
        <% if (trails.length === 0) { %>
          <p class="text-center text-muted mt-4">No trails found. Check the database connection.</p>
        <% } %>
      </div>
    </div>

      <%- include('partials/footer.ejs'); %>

      <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
      <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js" integrity="sha384-I7E8VVD/ismYTF4hNIPjVp/Zjvgyol6VFvRkX/vR+Vc4jQkC+hVqc2pM8ODewa9r" crossorigin="anonymous"></script>


    </body>
      
  
  
  </html>
    