<!DOCTYPE html>
<html lang="en">
<head>
    <link rel="icon" href="/assets/img/signpost.png">
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-FPZ4SZV14K"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-FPZ4SZV14K');
    </script>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= trail.name %> - Hikelah!</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@400..700&family=Inter:wght@100..900&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Open+Sans:ital,wght@0,300..800;1,300..800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/hikelah_style.css">
    <script src="/js/script.js"></script>
</head>
<body>

<%- include('partials/navbar.ejs'); %>

<div class="container mt-3 mb-2">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><a href="/" class="trail-breadcrumb-link">Home</a></li>
      <li class="breadcrumb-item"><a href="/explore" class="trail-breadcrumb-link">Explore</a></li>
      <li class="breadcrumb-item active" aria-current="page"><%= trail.name %></li>
    </ol>
  </nav>
</div>

<!-- Hero -->
<div class="trail-hero-wrap">
  <div class="trail-hero-img" style="background-image: url('<%= meta.imageUrl || '/assets/img/placeholder.jpeg' %>')"></div>
  <div class="trail-hero-overlay">
    <% if (!trail.isActive) { %>
      <span class="trail-status-badge badge-closed">Trail Closed</span>
    <% } else if (meta.headerSubtext) { %>
      <span class="trail-status-badge badge-open"><%= meta.headerSubtext %></span>
    <% } %>
    <h1 class="trail-hero-title"><%= trail.name %></h1>
    <% if (trail.difficulty) { %>
      <span class="trail-difficulty-hero difficulty-<%= trail.difficulty.toLowerCase() %>"><%= trail.difficulty %></span>
    <% } %>
  </div>
</div>

<!-- Closure alert -->
<% if (!trail.isActive) { %>
<div class="container mt-3">
  <div class="alert alert-danger d-flex align-items-center" role="alert">
    <i class="fas fa-exclamation-triangle me-2"></i>
    <div>
      <strong>This trail is currently closed.</strong>
      <% if (trail.closureReason) { %> <%= trail.closureReason %>.<% } %>
      <% if (trail.closureUntil) { %> Expected to reopen: <strong><%= new Date(trail.closureUntil).toLocaleDateString('en-SG', { day: 'numeric', month: 'long', year: 'numeric' }) %></strong>.<% } %>
    </div>
  </div>
</div>
<% } %>

<!-- Stat cards -->
<div class="container mt-3">
  <div class="row g-3 trail-stats-row">
    <div class="col-6 col-md-3">
      <div class="trail-stat-card">
        <i class="fas fa-route trail-stat-icon"></i>
        <div class="trail-stat-label">Distance</div>
        <div class="trail-stat-value"><%= meta.distanceText ? meta.distanceText.split('|')[0].trim() : (trail.lengthKm ? trail.lengthKm + ' km' : '—') %></div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="trail-stat-card">
        <i class="fas fa-clock trail-stat-icon"></i>
        <div class="trail-stat-label">Est. Duration</div>
        <div class="trail-stat-value"><%= meta.distanceText && meta.distanceText.includes('|') ? meta.distanceText.split('|')[1].trim() : (trail.estimatedHours ? trail.estimatedHours + 'h' : '—') %></div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="trail-stat-card">
        <i class="fas fa-mountain trail-stat-icon"></i>
        <div class="trail-stat-label">Difficulty</div>
        <div class="trail-stat-value <%= trail.difficulty ? 'difficulty-' + trail.difficulty.toLowerCase() : '' %>"><%= trail.difficulty || '—' %></div>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="trail-stat-card">
        <i class="fas fa-shoe-prints trail-stat-icon"></i>
        <div class="trail-stat-label">Terrain</div>
        <div class="trail-stat-value"><%= trail.terrainType || '—' %></div>
      </div>
    </div>
  </div>
</div>

<!-- Main content -->
<div class="container mt-4">
  <div class="row g-4">

    <!-- Left column -->
    <div class="col-lg-7">

      <!-- About -->
      <% if (trail.description) { %>
      <section class="trail-section">
        <h2 class="trail-section-heading">About this trail</h2>
        <p><%= trail.description %></p>
      </section>
      <% } %>

      <!-- What to Expect -->
      <section class="trail-section">
        <h2 class="trail-section-heading">What you'll see</h2>
        <div class="d-flex flex-wrap gap-2 mb-3">
          <% if (trail.forestedTrail) { %>
            <span class="trail-expect-badge"><i class="fas fa-tree me-1"></i>Forested Trail</span>
          <% } %>
          <% if (trail.casualWalk) { %>
            <span class="trail-expect-badge"><i class="fas fa-walking me-1"></i>Casual Walk</span>
          <% } %>
          <% if (trail.floraFaunaSpotting) { %>
            <span class="trail-expect-badge"><i class="fas fa-leaf me-1"></i>Flora &amp; Fauna</span>
          <% } %>
          <% if (trail.wildlifeSpotting) { %>
            <span class="trail-expect-badge"><i class="fas fa-paw me-1"></i>Wildlife</span>
          <% } %>
          <% if (!trail.forestedTrail && !trail.casualWalk && !trail.floraFaunaSpotting && !trail.wildlifeSpotting) { %>
            <span class="text-muted">No sightings data yet.</span>
          <% } %>
        </div>
        <% if (trail.elevationGainM) { %>
          <p class="text-muted mb-0"><i class="fas fa-level-up-alt me-1"></i>Elevation gain: <strong><%= trail.elevationGainM %>m</strong></p>
        <% } %>
      </section>

      <!-- Getting There -->
      <section class="trail-section">
        <h2 class="trail-section-heading">Getting There</h2>
        <div class="row g-3">
          <div class="col-sm-6">
            <div class="trail-info-tile">
              <i class="fas fa-train trail-info-icon"></i>
              <div>
                <div class="trail-info-tile-label">Nearest MRT</div>
                <div class="trail-info-tile-value"><%= trail.nearestMRT || 'Not available' %></div>
              </div>
            </div>
          </div>
          <div class="col-sm-6">
            <div class="trail-info-tile">
              <i class="fas fa-parking trail-info-icon"></i>
              <div>
                <div class="trail-info-tile-label">Carpark</div>
                <div class="trail-info-tile-value"><%= trail.parkingAvail || 'Not available' %></div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Facilities -->
      <section class="trail-section">
        <h2 class="trail-section-heading">Facilities &amp; Accessibility</h2>
        <div class="d-flex flex-wrap gap-2">
          <span class="trail-facility-badge <%= trail.toilets ? 'facility-yes' : 'facility-no' %>">
            <i class="fas fa-restroom me-1"></i>Toilets <%= trail.toilets ? '✓' : '✗' %>
          </span>
          <span class="trail-facility-badge <%= trail.shelters ? 'facility-yes' : 'facility-no' %>">
            <i class="fas fa-umbrella me-1"></i>Shelters <%= trail.shelters ? '✓' : '✗' %>
          </span>
          <span class="trail-facility-badge <%= trail.dogFriendly ? 'facility-yes' : 'facility-no' %>">
            <i class="fas fa-dog me-1"></i>Dog-friendly <%= trail.dogFriendly ? '✓' : '✗' %>
          </span>
          <span class="trail-facility-badge <%= trail.wheelchairAccess ? 'facility-yes' : 'facility-no' %>">
            <i class="fas fa-wheelchair me-1"></i>Wheelchair <%= trail.wheelchairAccess ? '✓' : '✗' %>
          </span>
        </div>
      </section>

      <!-- Official guide -->
      <% if (meta.trailGuideUrl) { %>
      <section class="trail-section">
        <a href="<%= meta.trailGuideUrl %>" target="_blank" rel="noopener noreferrer" class="btn hero-button">
          <i class="fas fa-external-link-alt me-2"></i>Official Trail Guide
        </a>
      </section>
      <% } %>

    </div><!-- /left col -->

    <!-- Right column: Map + Weather -->
    <div class="col-lg-5">

      <% if (trail.lat && trail.lng) { %>
      <div class="trail-section">
        <h2 class="trail-section-heading">Trail Location</h2>
        <div id="trail-map"></div>
        <p class="text-muted mt-2" style="font-size:0.8rem;">
          <i class="fas fa-map-marker-alt me-1"></i>
          <%= trail.lat.toFixed(5) %>, <%= trail.lng.toFixed(5) %>
        </p>
      </div>
      <% } %>

      <!-- Weather widget -->
      <div class="trail-section">
        <h2 class="trail-section-heading"><i class="fas fa-cloud-sun me-2"></i>Live Weather</h2>
        <div id="weather-loading" class="text-muted">
          <i class="fas fa-spinner fa-spin me-1"></i>Loading weather...
        </div>
        <div id="weather-content" style="display:none">
          <div class="weather-nowcast-card mb-3">
            <div class="d-flex align-items-center gap-3">
              <div id="weather-icon" class="weather-big-icon"></div>
              <div>
                <div id="weather-area" class="weather-area-label"></div>
                <div id="weather-forecast-text" class="weather-forecast-text"></div>
              </div>
            </div>
          </div>
          <div class="weather-forecast-label mb-2">Today's forecast</div>
          <div id="weather-periods" class="d-flex flex-wrap gap-2"></div>
        </div>
        <div id="weather-error" style="display:none" class="text-muted" style="font-size:0.85rem;">
          Weather data unavailable.
        </div>
        <p class="text-muted mt-2" style="font-size:0.75rem;">Source: data.gov.sg</p>
      </div>

    </div><!-- /right col -->
  </div>
</div>

<%- include('partials/footer.ejs'); %>

<!-- Google Maps -->
<% if (trail.lat && trail.lng) { %>
<script>
  var TRAIL_LAT = <%= trail.lat %>;
  var TRAIL_LNG = <%= trail.lng %>;
  var TRAIL_NAME = document.getElementById('trail-map') ? '<%= trail.name.replace(/\\/g, '\\\\').replace(/'/g, "\\'") %>' : '';

  function initTrailMap() {
    var trailLocation = { lat: TRAIL_LAT, lng: TRAIL_LNG };
    var map = new google.maps.Map(document.getElementById('trail-map'), {
      center: trailLocation,
      zoom: 15,
      styles: [
        { elementType: 'geometry', stylers: [{ color: '#e8f5e9' }] },
        { featureType: 'water', elementType: 'geometry', stylers: [{ color: '#b3e0f2' }] },
        { featureType: 'road', elementType: 'geometry', stylers: [{ color: '#ffffff' }] },
        { featureType: 'poi.park', elementType: 'geometry', stylers: [{ color: '#c8e6c9' }] }
      ],
      mapTypeControl: false,
      streetViewControl: false,
      fullscreenControl: true
    });
    new google.maps.Marker({
      position: trailLocation,
      map: map,
      title: TRAIL_NAME,
      icon: {
        path: google.maps.SymbolPath.CIRCLE,
        scale: 10,
        fillColor: '#3D550C',
        fillOpacity: 1,
        strokeColor: '#ffffff',
        strokeWeight: 2
      }
    });
  }
</script>
<script src="https://maps.googleapis.com/maps/api/js?key=<%= apiKey %>&callback=initTrailMap" async defer></script>
<% } %>

<!-- Weather fetch -->
<script>
(function() {
  var REGION_KEY = '<%= regionKey %>';
  var TRAIL_LAT_W = <%= trail.lat || 'null' %>;
  var TRAIL_LNG_W = <%= trail.lng || 'null' %>;

  var FORECAST_ICONS = {
    'fair': 'fas fa-sun',
    'sunny': 'fas fa-sun',
    'partly cloudy': 'fas fa-cloud-sun',
    'cloudy': 'fas fa-cloud',
    'overcast': 'fas fa-cloud',
    'hazy': 'fas fa-smog',
    'light showers': 'fas fa-cloud-rain',
    'showers': 'fas fa-cloud-showers-heavy',
    'heavy showers': 'fas fa-cloud-showers-heavy',
    'thundery showers': 'fas fa-bolt',
    'heavy thundery showers': 'fas fa-bolt',
    'windy': 'fas fa-wind',
    'light rain': 'fas fa-cloud-rain',
    'moderate rain': 'fas fa-cloud-rain',
    'heavy rain': 'fas fa-cloud-showers-heavy'
  };

  function getWeatherIcon(forecast) {
    if (!forecast) return 'fas fa-cloud';
    var lower = forecast.toLowerCase();
    var keys = Object.keys(FORECAST_ICONS);
    for (var i = 0; i < keys.length; i++) {
      if (lower.indexOf(keys[i]) !== -1) return FORECAST_ICONS[keys[i]];
    }
    return 'fas fa-cloud-sun';
  }

  function haversineDistance(lat1, lng1, lat2, lng2) {
    var R = 6371;
    var dLat = (lat2 - lat1) * Math.PI / 180;
    var dLng = (lng2 - lng1) * Math.PI / 180;
    var a = Math.sin(dLat/2)*Math.sin(dLat/2) +
      Math.cos(lat1*Math.PI/180) * Math.cos(lat2*Math.PI/180) *
      Math.sin(dLng/2)*Math.sin(dLng/2);
    return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
  }

  function formatPeriod(isoStart, isoEnd) {
    var start = new Date(isoStart);
    var end = new Date(isoEnd);
    var fmt = function(t) { return t.toLocaleTimeString('en-SG', { hour: 'numeric', hour12: true }); };
    return fmt(start) + ' \u2013 ' + fmt(end);
  }

  function buildWeatherPeriodCard(timeLabel, iconClass, forecastText) {
    var card = document.createElement('div');
    card.className = 'weather-period-card';

    var timeEl = document.createElement('div');
    timeEl.className = 'weather-period-time';
    timeEl.textContent = timeLabel;
    card.appendChild(timeEl);

    var iconEl = document.createElement('i');
    iconClass.split(' ').forEach(function(cls) { iconEl.classList.add(cls); });
    iconEl.classList.add('weather-period-icon');
    card.appendChild(iconEl);

    var labelEl = document.createElement('div');
    labelEl.className = 'weather-period-label';
    labelEl.textContent = forecastText;
    card.appendChild(labelEl);

    return card;
  }

  async function loadWeather() {
    try {
      var responses = await Promise.all([
        fetch('https://api-open.data.gov.sg/v2/real-time/api/two-hr-weather'),
        fetch('https://api-open.data.gov.sg/v2/real-time/api/24hr-weather')
      ]);
      var nowcastData = await responses[0].json();
      var forecastData = await responses[1].json();

      var items = nowcastData && nowcastData.data && nowcastData.data.items && nowcastData.data.items[0];
      var areaMeta = nowcastData && nowcastData.data && nowcastData.data.area_metadata;
      var areaName = null;
      var areaForecast = null;

      if (items && areaMeta && TRAIL_LAT_W && TRAIL_LNG_W) {
        var minDist = Infinity;
        for (var i = 0; i < areaMeta.length; i++) {
          var area = areaMeta[i];
          var d = haversineDistance(TRAIL_LAT_W, TRAIL_LNG_W, area.label_location.latitude, area.label_location.longitude);
          if (d < minDist) {
            minDist = d;
            areaName = area.name;
          }
        }
        var forecasts = items.forecasts || [];
        for (var j = 0; j < forecasts.length; j++) {
          if (forecasts[j].area === areaName) {
            areaForecast = forecasts[j].forecast;
            break;
          }
        }
      }

      if (areaForecast) {
        var iconEl = document.createElement('i');
        getWeatherIcon(areaForecast).split(' ').forEach(function(cls) { iconEl.classList.add(cls); });
        iconEl.classList.add('weather-icon-fa');
        document.getElementById('weather-icon').appendChild(iconEl);
        document.getElementById('weather-area').textContent = areaName;
        document.getElementById('weather-forecast-text').textContent = areaForecast;
      }

      var record = forecastData && forecastData.data && forecastData.data.records && forecastData.data.records[0];
      if (record && record.periods) {
        var container = document.getElementById('weather-periods');
        record.periods.forEach(function(period) {
          var regionForecast = (period.regions && (period.regions[REGION_KEY] || period.regions.central)) || '\u2014';
          var timeLabel = formatPeriod(period.timePeriod.start, period.timePeriod.end);
          container.appendChild(buildWeatherPeriodCard(timeLabel, getWeatherIcon(regionForecast), regionForecast));
        });
      }

      document.getElementById('weather-loading').style.display = 'none';
      document.getElementById('weather-content').style.display = 'block';
    } catch (err) {
      document.getElementById('weather-loading').style.display = 'none';
      document.getElementById('weather-error').style.display = 'block';
    }
  }

  document.addEventListener('DOMContentLoaded', loadWeather);
})();
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
</body>
</html>
